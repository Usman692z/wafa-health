rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isRole(role) {
      return isAuth() && get(/databases/$(database)/documents/users/$(uid())).data.role == role;
    }

    function isAdmin() { return isRole('admin'); }
    function isDoctor() { return isRole('doctor'); }
    function isPatient() { return isRole('patient'); }

    function isNotBlocked() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(uid())).data.isBlocked != true;
    }

    // ─── Users ────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read approved doctors
      allow read: if isAuth() && (
        uid() == userId ||
        isAdmin() ||
        (resource.data.role == 'doctor' && resource.data.isApproved == true)
      );
      // Create own profile at signup
      allow create: if isAuth() && uid() == userId;
      // Update own profile, or admin can update any
      allow update: if isAuth() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Appointments ─────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.patientId == uid() ||
        resource.data.doctorId == uid()
      );
      allow create: if isAuth() && isNotBlocked() &&
        request.resource.data.patientId == uid();
      allow update: if isAuth() && (
        isAdmin() ||
        (resource.data.doctorId == uid()) ||
        // Patient can only cancel
        (resource.data.patientId == uid() && request.resource.data.status == 'cancelled')
      );
      allow delete: if isAdmin();
    }

    // ─── Chat Rooms ───────────────────────────────────────────
    match /chatRooms/{roomId} {
      allow read, write: if isAuth() &&
        resource.data.participants.hasAny([uid()]);
      allow create: if isAuth() && isNotBlocked();

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if isAuth() &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.hasAny([uid()]);
        allow create: if isAuth() && isNotBlocked() &&
          request.resource.data.senderId == uid() &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.hasAny([uid()]);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ─── Prescriptions ────────────────────────────────────────
    match /prescriptions/{prescriptionId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.patientId == uid() ||
        resource.data.doctorId == uid()
      );
      allow create: if isAuth() && isDoctor() &&
        request.resource.data.doctorId == uid();
      allow update: if isAdmin() || (
        isDoctor() && resource.data.doctorId == uid()
      );
      allow delete: if isAdmin();
    }

    // ─── Payments ─────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.patientId == uid() ||
        resource.data.doctorId == uid()
      );
      allow create: if isAuth() && isNotBlocked() &&
        request.resource.data.patientId == uid();
      // Only admin can verify/reject
      allow update: if isAdmin() || (
        isPatient() && resource.data.patientId == uid() &&
        // Patient can only update screenshot before verification
        resource.data.status == 'pending'
      );
      allow delete: if isAdmin();
    }

    // ─── Reviews ─────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true; // public
      allow create: if isAuth() && isNotBlocked() &&
        request.resource.data.patientId == uid();
      allow update, delete: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == uid();
      allow create: if isAdmin(); // Only cloud functions/admin create notifications
      allow update: if isAuth() && resource.data.userId == uid() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAdmin() || (isAuth() && resource.data.userId == uid());
    }

    // ─── Video Calls (WebRTC signaling) ───────────────────────
    match /calls/{callId} {
      allow read, write: if isAuth() && isNotBlocked();

      match /iceCandidates_doctor/{candidateId} {
        allow read, write: if isAuth() && isNotBlocked();
      }
      match /iceCandidates_patient/{candidateId} {
        allow read, write: if isAuth() && isNotBlocked();
      }
    }

    // ─── Settings (admin only) ────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── Banners (public read, admin write) ───────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── FAQs (public read, admin write) ─────────────────────
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
